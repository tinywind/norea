{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Norea",
  "version": "0.1.0",
  "identifier": "io.github.tinywind.norea",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Norea",
        "width": 1100,
        "height": 720,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$DOCUMENT/**", "$DOWNLOAD/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "linux": {
      "rpm": {
        "compression": {
          "type": "none"
        }
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:norea.db"]
    },
    "deep-link": {
      "mobile": [
        {
          "host": "repo",
          "pathPrefix": ["/add"]
        }
      ],
      "desktop": {
        "schemes": ["norea"]
      }
    }
  }
}
